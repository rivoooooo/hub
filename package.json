{
  "name": "dev-home",
  "version": "1.0.0",
  "description": "Dev Home — developer tools hub with browser control and more",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "vp fmt .",
    "lint": "vp lint .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "npm run build:app-runner && electron-vite dev",
    "build": "npm run typecheck && electron-vite build && npm run build:app-runner",
    "build:app-runner": "node build-app-runner.mjs",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && npm run build:app-runner && electron-builder --mac",
    "build:linux": "electron-vite build && npm run build:app-runner && electron-builder --linux",
    "download-electron": "node scripts/download-electron.mjs",
    "prepare": "vp config"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "cheerio": "^1.2.0",
    "electron-updater": "^6.3.9",
    "http-proxy-agent": "^9.1.0",
    "https-proxy-agent": "^9.1.0",
    "lucide-react": "^1.18.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@inlang/paraglide-js": "^2.19.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@11.6.0"
}
